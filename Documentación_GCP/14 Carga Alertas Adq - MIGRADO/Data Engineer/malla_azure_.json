                                    "value": "@concat('Raw/Monitor/Transaccional/',toLower(variables('var_tabla')),'/',substring(item().Fecha,0,4),'/',substring(item().Fecha,4,2))",
                                    "type": "Expression"
                                }
                            }
                        },
                        {
                            "name": "var_nombre_archivo",
                            "type": "SetVariable",
                            "dependsOn": [
                                {
                                    "activity": "var_ruta",
                                    "dependencyConditions": [
                                        "Succeeded"
                                    ]
                                }
                            ],
                            "policy": {
                                "secureOutput": false,
                                "secureInput": false
                            },
                            "userProperties": [],
                            "typeProperties": {
                                "variableName": "var_nombre_archivo",
                                "value": {
                                    "value": "@concat(toLower(variables('var_tabla')),'_',substring(item().Fecha,0,8),'.parquet')",
                                    "type": "Expression"
                                }
                            }
                        },
                        {
                            "name": "cd izp_acf_vwj08881",
                            "type": "Copy",
                            "dependsOn": [
