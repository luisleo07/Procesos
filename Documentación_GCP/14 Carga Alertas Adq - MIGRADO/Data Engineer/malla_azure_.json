{
    "name": "pl_t_izp_acf_vwj08851_sql_adls_prd",
    "properties": {
        "activities": [
            {
                "name": "Fecha",
                "type": "Lookup",
                "dependsOn": [],
                "policy": {
                    "timeout": "7.00:00:00",
                    "retry": 0,
                    "retryIntervalInSeconds": 30,
                    "secureOutput": false,
                    "secureInput": false
                },
                "userProperties": [],
                "typeProperties": {
                    "source": {
                        "type": "SqlServerSource",
                        "sqlReaderQuery": {
                            "value": "@concat('declare @fecha_inicial date;\ndeclare @fecha_final date;\nset @fecha_inicial =''',pipeline().parameters.pFechaInicial,''';\nset @fecha_final =''',pipeline().parameters.pFechaFinal,''';\ndeclare @dias int;\nselect @dias= datediff(day,@fecha_inicial,@fecha_final);\ndeclare @i int;\nset @i=0;\n\nIF OBJECT_ID(N''tempdb..#myTabla1'') IS NOT NULL\nBEGIN\n   DROP TABLE #myTabla1;\nEND \n\ncreate TABLE #myTabla1 (FECHA varchar(10) null);\nwhile @i<=@dias\nbegin\n\tinsert into #myTabla1 select Concat(CONVERT(VARCHAR(10),DATEADD(DD,@i,@fecha_inicial),112),''.0'')\n\tset @i=@i+1;\nend\n\nselect *from #myTabla1 ORDER BY FECHA ASC;\n')",
                            "type": "Expression"
                        },
                        "queryTimeout": "02:00:00",
                        "partitionOption": "None"
                    },
                    "dataset": {
                        "referenceName": "IST_Tablas",
                        "type": "DatasetReference"
                    },
                    "firstRowOnly": false
                }
            },
            {
                "name": "ForEach izp_acf_vwj08851",
                "type": "ForEach",
                "dependsOn": [
                    {
                        "activity": "Fecha",
                        "dependencyConditions": [
                            "Succeeded"
                        ]
                    }
                ],
                "userProperties": [],
                "typeProperties": {
                    "items": {
                        "value": "@activity('Fecha').output.value",
                        "type": "Expression"
                    },
                    "isSequential": true,
                    "activities": [
