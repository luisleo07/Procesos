                                            "type": "Expression"
                                        }
                                    }
                                }
                            ]
                        },
                        {
                            "name": "week_num",
                            "type": "Lookup",
                            "dependsOn": [],
                            "policy": {
                                "timeout": "0.12:00:00",
                                "retry": 0,
                                "retryIntervalInSeconds": 30,
                                "secureOutput": false,
                                "secureInput": false
                            },
                            "userProperties": [],
                            "typeProperties": {
                                "source": {
                                    "type": "SqlServerSource",
                                    "sqlReaderQuery": {
                                        "value": "@concat('\n    DECLARE @Fecha DATE;\n    SET @Fecha = ''',substring(item().Fecha,0,8),''';\n    DECLARE @NumeroSemana INT;\n    DECLARE @AñoActual INT = YEAR(@Fecha);\n    DECLARE @PrimerDiaAño DATE = DATEFROMPARTS(@AñoActual, 1, 1);\n    \n    -- Ajustar según el primer día de la semana configurado\n    DECLARE @DiaSemanaInicio INT = DATEPART(WEEKDAY, @PrimerDiaAño);\n    \n    -- Convertir de formato SQL (domingo=1) al formato personalizado\n    SET @DiaSemanaInicio = (@DiaSemanaInicio + @@DATEFIRST - 1) % 7 + 1;\n    \n    -- Calcular el número de semana basado en la diferencia de días\n    SET @NumeroSemana = (DATEDIFF(DAY, @PrimerDiaAño, @Fecha) + @DiaSemanaInicio - 2) / 7 + 1;\n    \n    SELECT CONVERT(VARCHAR(2), @NumeroSemana) AS week_number;\n')",
                                        "type": "Expression"
                                    },
                                    "queryTimeout": "02:00:00",
                                    "partitionOption": "None"
                                },
                                "dataset": {
                                    "referenceName": "IST_Tablas",
                                    "type": "DatasetReference"
                                },
                                "firstRowOnly": true
                            }
                        }
                    ]
                }
            }
        ],
